{
  "name": "react-noti",
  "version": "4.0.3",
  "description": "react-noti - Toast Notifications made easy",
  "type": "commonjs",
  "main": "dist/react-noti.cjs",
  "module": "dist/react-noti.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/react-noti.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/react-noti.cjs"
      }
    }
  },
  "sideEffects": false,
  "scripts": {
    "start": "vite --config examples/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "clean": "rimraf dist coverage",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "lint:format": "prettier \"**/*.{md,json,yml,css}\" --check",
    "lint:format:fix": "prettier \"**/*.{md,json,yml,css}\" --write",
    "typecheck": "tsc --noEmit",
    "validate:package": "publint && attw --pack",
    "build": "npm run clean && vite build",
    "examples:build": "vite build --config examples/vite.config.ts",
    "examples:deploy": "gh-pages -d ./examples/build",
    "commit": "git-cz",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=18.18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vitaliiburlaka/react-noti.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "author": "Vitalii Burlaka <vitalii.burlaka@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/vitaliiburlaka/react-noti/issues"
  },
  "homepage": "https://vitaliiburlaka.github.io/react-noti",
  "keywords": [
    "react",
    "notification",
    "toast",
    "react-noti",
    "push",
    "alert"
  ],
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@eslint/js": "^9.39.4",
    "@microsoft/api-extractor": "^7.58.9",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "cz-conventional-changelog": "^3.3.0",
    "doctoc": "^2.1.0",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "gh-pages": "^6.3.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4",
    "publint": "^0.3.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rimraf": "^6.0.1",
    "semantic-release": "^25.0.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "react": "^19.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{md,json,yml,yaml,css}": [
      "prettier --write"
    ],
    "README.md": [
      "doctoc --maxlevel 4 --notitle"
    ]
  },
  "browserslist": {
    "production": [
      "last 2 years",
      ">0.5%",
      "not dead"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
