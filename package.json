{
  "name": "react-noti",
  "version": "0.0.0-semantically-released",
  "description": "react-noti - Toast Notifications made easy",
  "main": "dist/react-noti.cjs.js",
  "module": "dist/react-noti.esm.js",
  "style": "dist/react-noti.css",
  "scripts": {
    "start": "cross-env NODE_ENV=development webpack serve --open",
    "test": "cross-env NODE_ENV=test jest",
    "test:watch": "npm test -- --watch",
    "coverage": "npm test -- --coverage",
    "clean": "rimraf dist coverage",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "lint:format": "prettier \"**/*.{md,json,yml,css}\" --check",
    "lint:format:fix": "prettier \"**/*.{md,json,yml,css}\" --write",
    "typecheck": "tsc --noEmit",
    "build": "npm run clean && cross-env NODE_ENV=production rollup -c",
    "examples:build": "cross-env NODE_ENV=production GENERATE_SOURCEMAP=false PUBLIC_URL=/react-noti/ webpack --progress --config webpack.config.js",
    "examples:deploy": "gh-pages -d ./examples/build",
    "examples:analyze": "npm run examples:build -- --env analyze",
    "commit": "git-cz",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=18.18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vitaliiburlaka/react-noti.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "author": "Vitalii Burlaka <vitalii.burlaka@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/vitaliiburlaka/react-noti/issues"
  },
  "homepage": "https://vitaliiburlaka.github.io/react-noti",
  "keywords": [
    "react",
    "notification",
    "toast",
    "react-noti",
    "push",
    "alert"
  ],
  "dependencies": {
    "@babel/runtime": "^7.28.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.0",
    "@babel/core": "^7.28.0",
    "@babel/plugin-transform-runtime": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.29.7",
    "@babel/register": "^7.27.1",
    "@emotion/babel-plugin": "^11.13.5",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.1",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-url": "^8.0.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@svgr/rollup": "^8.1.0",
    "@svgr/webpack": "^8.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "babel-jest": "^30.4.1",
    "babel-loader": "^10.0.0",
    "case-sensitive-paths-webpack-plugin": "^2.4.0",
    "clean-webpack-plugin": "^4.0.0",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "cz-conventional-changelog": "^3.3.0",
    "doctoc": "^2.1.0",
    "eslint": "^9.30.1",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-webpack-plugin": "^5.0.2",
    "file-loader": "^6.2.0",
    "gh-pages": "^6.3.0",
    "globals": "^15.14.0",
    "html-webpack-plugin": "^5.6.3",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lint-staged": "^16.4.0",
    "mini-css-extract-plugin": "^2.9.2",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-loader": "^8.1.1",
    "postcss-normalize": "^13.0.1",
    "postcss-preset-env": "^10.2.4",
    "postcss-safe-parser": "^7.0.1",
    "postcss-url": "^10.1.3",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-refresh": "^0.17.0",
    "resolve-url-loader": "^5.0.0",
    "rimraf": "^6.0.1",
    "rollup": "^4.62.0",
    "rollup-plugin-filesize": "^10.0.0",
    "rollup-plugin-postcss": "^4.0.2",
    "sass": "^1.89.2",
    "sass-loader": "^16.0.5",
    "semantic-release": "^25.0.5",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.3.14",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "url-loader": "^4.1.1",
    "webpack": "^5.107.2",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  },
  "peerDependencies": {
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{md,json,yml,yaml,css}": [
      "prettier --write"
    ],
    "README.md": [
      "doctoc --maxlevel 4 --notitle"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm run coverage"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
